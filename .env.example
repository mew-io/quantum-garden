# =============================================================================
# Quantum Garden Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# For local development with Docker: postgresql://postgres:postgres@localhost:13318/quantum_garden
# For Vercel Postgres: Copy from your Vercel dashboard
DATABASE_URL="postgresql://postgres:postgres@localhost:13318/quantum_garden"

# -----------------------------------------------------------------------------
# IonQ Quantum Computing
# -----------------------------------------------------------------------------
# Get your API key from: https://cloud.ionq.com/settings/keys
# This is used to submit quantum circuits to IonQ hardware
IONQ_API_KEY="your-ionq-api-key-here"

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Base URL for the application (used for CORS and callbacks)
# Development: http://localhost:14923
# Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:14923"

# Quantum service URL (for local development)
# In production on Vercel, this is handled automatically via serverless functions
QUANTUM_SERVICE_URL="http://localhost:18742"

# -----------------------------------------------------------------------------
# Optional: Development Settings
# -----------------------------------------------------------------------------
# Set to 'true' to use IonQ simulator instead of real hardware
# Useful for development to avoid consuming compute credits
IONQ_USE_SIMULATOR="true"

# -----------------------------------------------------------------------------
# Cron Job Security (Production Only)
# -----------------------------------------------------------------------------
# Secret key for authenticating scheduled evolution jobs
# Generate with: openssl rand -base64 32
# Required in production for Vercel Cron authentication
# In development, cron jobs work without this secret
CRON_SECRET="your-secure-secret-here"

{
  "name": "quantum-garden",
  "version": "0.1.0",
  "private": true,
  "description": "A slow-evolving generative environment where plants exist in quantum superposition until observed",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/quantum-garden.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:push": "pnpm --filter web db:push",
    "db:generate": "pnpm --filter web db:generate",
    "db:studio": "pnpm --filter web db:studio",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@types/three": "^0.182.0",
    "three": "^0.182.0"
  }
}
